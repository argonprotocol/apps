{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "dev",
  "description": "Dev-only localhost access",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://localhost:*/*"
        },
        {
          "url": "https://localhost:*/*"
        },
        {
          "url": "http://127.0.0.1:*/*"
        },
        {
          "url": "https://127.0.0.1:*/*"
        },
        {
          "url": "https://*"
        }
      ]
    }
  ]
}
