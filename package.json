{
  "name": "argon-apps",
  "private": true,
  "version": "1.4.3",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "preinstall": "husky install",
    "precommit": "tsx scripts/checkPrecommit.ts && yarn check:operation-rules",
    "cli": "yarn workspace @argonprotocol/cli run cli",
    "tsc": "tsc && yarn workspaces foreach --all run tsc",
    "tsc:watch": "tsc --watch",
    "build": "yarn build:version && yarn build:server && vue-tsc --noEmit && vite build",
    "build:workspace": "yarn workspaces foreach --all run build",
    "build:indexer": "yarn workspace @argonprotocol/apps-indexer run build",
    "build:server": "yarn workspace @argonprotocol/apps-bot run build && yarn workspace @argonprotocol/apps-router run build && tsx scripts/buildServer.ts",
    "build:version": "tsx scripts/syncVersions.ts",
    "build:config": "tsx scripts/updateNetworkConfigs.ts",
    "clean:dev:docker": "tsx scripts/cleanDevDocker.ts && ARGON_APP_INSTANCE=ops2 tsx scripts/cleanDevDocker.ts",
    "dev": "vite",
    "dev:gateway-certs": "tsx scripts/devGatewayCerts.ts",
    "dev:docker": "yarn build:indexer && yarn build:server && yarn clean:dev:docker && yarn dev:gateway-certs && yarn docker:up && yarn tauri:dev:docker",
    "dev:docker:custom": "ARGON_CHAIN=/chainspec.raw.json yarn dev:docker",
    "dev:fund": "tsx e2e/scripts/fundArgonAccount.ts",
    "dev:argon:add-argn": "tsx e2e/scripts/fundArgonAccount.ts --token=ARGN",
    "dev:argon:add-argnot": "tsx e2e/scripts/fundArgonAccount.ts --token=ARGNOT",
    "dev:ethereum:add-eth": "tsx e2e/scripts/fundDevEthereumAccount.ts",
    "dev:ethereum:add-usdc": "tsx e2e/scripts/fundDevEthereumAccount.ts --token=USDC",
    "dev:ethereum:add-argn": "tsx e2e/scripts/fundDevEthereumTokens.ts --token=ARGN",
    "dev:ethereum:add-argnot": "tsx e2e/scripts/fundDevEthereumTokens.ts --token=ARGNOT",
    "dev:ethereum:force-update-global-issuance-council": "tsx e2e/scripts/forceUpdateGlobalIssuanceCouncil.ts",
    "dev:upstream:invite": "tsx e2e/scripts/devUpstreamInvite.ts",
    "e2e:prepare": "yarn build:server",
    "e2e:docker": "yarn workspace @argonprotocol/apps-e2e run flows",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tsx src-tauri/dev.ts",
    "tauri:dev:local": "NODE_ENV=localnet yarn tauri:dev",
    "tauri:dev:docker": "RUST_BACKTRACE=full ARGON_APP_INSTANCE=${ARGON_APP_INSTANCE:-e2e} ARGON_NETWORK_NAME=dev-docker yarn tauri:dev",
    "tauri:dev:docker:app2": "JOIN_COMPOSE_NETWORK=${JOIN_COMPOSE_NETWORK:-dev-docker-e2e} ARGON_DEV_ETHEREUM=0 ARGON_APP_INSTANCE=${ARGON_APP_INSTANCE:-app2:1421} yarn tauri:dev:docker",
    "lint": "prettier -w bot core src-vue cli e2e",
    "lint:check": "prettier --check bot core cli src-vue e2e && eslint bot core cli src-vue e2e --ext .ts --cache --max-warnings=0 && yarn check:operation-rules",
    "check:operation-rules": "yarn workspace @argonprotocol/apps-e2e run check:operation-rules",
    "eslint": "eslint router bot core cli src-vue e2e --ext .ts --cache --fix",
    "test": "vitest --run",
    "typecheck": "vue-tsc --noEmit && yarn workspaces foreach --all run tsc --noEmit",
    "update-data": "yarn workspace @argonprotocol/apps-core run update-frames && tsx data-generators/all.ts",
    "mainchain:pin": "tsx scripts/updateRuntimePin.ts",
    "docker:argon:download": "tsx e2e/argon/download.ts",
    "docker:argon:chainspec": "tsx e2e/argon/chainspec.ts",
    "docker:argon": "yarn docker:argon:download && cd e2e/argon && docker compose --env-file=.env --profile=all -f docker-compose.yml -f miners.docker-compose.yml -f upstream-server.docker-compose.yml -f indexer.docker-compose.yml -f chainspec.docker-compose.yml",
    "docker:down": "yarn docker:argon --profile=upstream down -v --timeout=0",
    "docker:pull": "yarn docker:argon --profile=upstream pull",
    "docker:up:workspace": "yarn docker:down && yarn docker:argon -f miners.workspace.docker-compose.yml up -d --wait",
    "docker:up:test": "yarn docker:argon -f miners.workspace.docker-compose.yml config",
    "docker:up": "yarn docker:down && yarn docker:argon up -d --force-recreate --wait",
    "docker:btc": "cd e2e/argon && docker compose --profile tooling run --rm btc-cli",
    "prepare": "husky",
    "postversion": "yarn update-data && yarn build:version"
  },
  "dependencies": {
    "@actions/github": "^9.1.1",
    "@argonprotocol/apps-bot": "workspace:*",
    "@argonprotocol/apps-core": "workspace:*",
    "@argonprotocol/bitcoin": "1.4.9-dev.3a35d811",
    "@argonprotocol/mainchain": "1.4.9-dev.3a35d811",
    "@chenfengyuan/vue-countdown": "^2.1.3",
    "@ethereumjs/rlp": "^10.1.1",
    "@ethereumjs/trie": "^6.2.1",
    "@flaticon/flaticon-uicons": "^3.3.1",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@iconify/vue": "^5.0.0",
    "@mempool/mempool.js": "^3.0.0",
    "@ngraveio/bc-ur": "^1.1.13",
    "@polkadot/util": "^14.0.3",
    "@polkadot/util-crypto": "^14.0.3",
    "@scure/bip39": "^1.6.0",
    "@tailwindcss/vite": "^4.1.12",
    "@tauri-apps/api": "~2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.0",
    "@tauri-apps/plugin-dialog": "~2.4.0",
    "@tauri-apps/plugin-fs": "~2.4.2",
    "@tauri-apps/plugin-http": "~2.5.2",
    "@tauri-apps/plugin-log": "~2.7.0",
    "@tauri-apps/plugin-opener": "~2.5.0",
    "@tauri-apps/plugin-os": "~2.3.1",
    "@tauri-apps/plugin-process": "~2.3.0",
    "@tauri-apps/plugin-shell": "~2.3.1",
    "@tauri-apps/plugin-sql": "~2.3.0",
    "@tauri-apps/plugin-updater": "~2.9.0",
    "@tauri-controls/vue": "^0.4.0",
    "@uniswap/sdk-core": "^7.13.0",
    "@uniswap/v3-sdk": "^3.30.0",
    "@vueuse/core": "^13.9.0",
    "bignumber.js": "^9.3.1",
    "buffer": "^6.0.3",
    "camelcase-keys": "^9.1.3",
    "chart.js": "^4.4.9",
    "chartjs-adapter-dayjs-4": "^1.0.4",
    "d3": "^7.9.0",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.1",
    "events": "^3.3.0",
    "jsbi": "^4.3.2",
    "mitt": "^3.0.1",
    "motion-v": "^1.7.0",
    "nanoid": "^5.1.6",
    "numeral": "^2.0.6",
    "ordinal": "^1.0.3",
    "pako": "^2.1.0",
    "pinia": "^3.0.3",
    "qrcode": "^1.5.4",
    "qrcode-vue": "^1.2.0",
    "reka-ui": "^2.9.6",
    "sass-embedded": "^1.90.0",
    "semver": "^7.7.3",
    "sortablejs": "^1.15.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16",
    "viem": "^2.48.11",
    "vue": "^3.5.20",
    "zod": "^3.25.55"
  },
  "workspaces": [
    "bot",
    "core",
    "router",
    "cli",
    "indexer",
    "e2e"
  ],
  "devDependencies": {
    "@argonprotocol/testing": "1.4.9-dev.3a35d811",
    "@scure/bip39": "^1.6.0",
    "@tauri-apps/cli": "^2.11.0",
    "@types/bun": "^1.2.22",
    "@types/d3": "^7",
    "@types/events": "^3",
    "@types/node": "^22.18.0",
    "@types/numeral": "^2.0.5",
    "@types/pako": "^2",
    "@types/qrcode": "^1.5.5",
    "@types/semver": "^7.7.1",
    "@types/sortablejs": "^1",
    "@vitejs/plugin-vue": "^6.0.1",
    "clsx": "^2.1.1",
    "eslint": "9.34.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "4.16.1",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "0.6.14",
    "svgo": "^4.0.1",
    "tar": "^7.5.16",
    "tsx": "^4.20.5",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.1.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.2.12"
  },
  "dependenciesMeta": {
    "@swc/core": {
      "built": true
    },
    "@tailwindcss/oxide": {
      "built": true
    },
    "esbuild": {
