{
  "name": "@argonprotocol/apps-e2e",
  "private": true,
  "type": "module",
  "scripts": {
    "flows": "yarn --cwd .. e2e:prepare && tsx runFlows.ts",
    "flows:console": "yarn --cwd .. e2e:prepare && tsx scripts/operationConsole.ts",
    "test": "yarn --cwd .. e2e:prepare && yarn --cwd .. vitest --run --project e2e",
    "test:flows": "yarn flows",
    "lint": "yarn lint:check",
    "lint:check": "yarn check:operation-rules",
    "check:operation-rules": "node scripts/checkOperationRules.mjs",
    "tsc": "yarn check:operation-rules && tsc --noEmit",
    "build": "yarn check:operation-rules && tsc --noEmit"
  },
  "devDependencies": {
    "@argonprotocol/apps-bot": "workspace:*",
    "@argonprotocol/apps-core": "workspace:*",
    "@argonprotocol/mainchain": "1.4.7-dev.777a8466",
    "@types/ws": "^8.5.13",
    "docker-compose": "^1.2.0",
    "tsx": "^4.20.5",
    "typescript": "^5.0.0",
    "ws": "^8.21.0"
  }
}
